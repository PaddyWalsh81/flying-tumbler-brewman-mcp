# Brewman MCP server — environment variables
# Copy to .env for local dev, or set these in your host's project settings (e.g. Vercel).
# NEVER commit real values. The token is a secret.

# Required: API token generated from a DEDICATED Brewman API user
# (Brewman > that user's screen > generate API token).
BREWMAN_API_TOKEN=

# Required by most methods: the tenant / group id shown on the token screen,
# or fetched via the brewman_get_user_context tool.
BREWMAN_TENANT_ID=

# Optional overrides
# BREWMAN_BASE_URL=https://brewman.premiersystems.com
# BREWMAN_TENANT_FIELD=groupId   # body key for the tenant id, if a method documents a different one
# TRANSPORT=http                 # http (default) or stdio
# PORT=3000
